# Stripe — direct shop checkout (required for "Buy on MacTech")
# Get from https://dashboard.stripe.com/apikeys (use test keys while testing)
STRIPE_SECRET_KEY=sk_test_...

# Optional — defaults shown (update when you know real shipping costs)
SITE_URL=https://mactechgear.ca
PRODUCT_PRICE_CENTS=11989
SHIPPING_CA_CENTS=1500
SHIPPING_US_CENTS=2500

# Returns (optional — return form still works without these)
RETURN_TO_EMAIL=you@example.com
RESEND_API_KEY=
RETURN_FROM_EMAIL=MacTech Gear <returns@mactechgear.ca>

# Mission Control returns inbox (optional — customer form still works if these are unset)
# MISSION_CONTROL_RETURN_WEBHOOK_URL=https://mission-control-black-nu.vercel.app/api/webhooks/return-request
# MISSION_CONTROL_RETURN_WEBHOOK_SECRET=same-secret-as-RETURN_WEBHOOK_SECRET-on-mission-control

# Mission Control shop analytics (optional — site works without these; no traffic in dashboard until set)
# MISSION_CONTROL_ANALYTICS_URL=https://mission-control-black-nu.vercel.app/api/webhooks/mactech-analytics
# MISSION_CONTROL_ANALYTICS_SECRET=same-secret-as-MACTECH_ANALYTICS_SECRET-on-mission-control

# Instagram API (optional — Behold feed is primary)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_MEDIA_LIMIT=12
INSTAGRAM_DISPLAY_COUNT=4
